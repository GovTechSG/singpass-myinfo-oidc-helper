# ==============================================================================
# MyInfo
# ==============================================================================
SINGPASS_ESERVICE_ID=
MY_INFO_ENVIRONMENT=
MY_INFO_PUBLIC_CERT=
MY_INFO_PRIVATE_KEY=
MY_INFO_PRIVATE_KEY_PASS=
MY_INFO_CLIENT_ID=
MY_INFO_JWE_PRIVATE_KEY=

# Optional
MY_INFO_OVERRIDE_PERSON_BASIC_URL=
MY_INFO_OVERRIDE_PROFILE_STATUS_URL=

# ==============================================================================
# SingPass NDI OIDC (v1)
# ==============================================================================
SINGPASS_AUTH_CLIENT_ID=
SINGPASS_AUTH_OIDC_CONFIG_URL=
SINGPASS_AUTH_REDIRECT_URL=
SINGPASS_AUTH_JWE_DECRYPT_KEY=
SINGPASS_AUTH_JWE_DECRYPT_KEY_FORMAT=
SINGPASS_AUTH_CLIENT_ASSERTION_SIGN_KEY=
SINGPASS_AUTH_CLIENT_ASSERTION_SIGN_KEY_ALG=

# ==============================================================================
# SingPass NDI OIDC FAPI 2.0 — Login app
# Run the "Key generation utility" test in singpass-helper-ndi-v2.ext.spec.ts
# to generate keys, then register the JWKS in the Singpass Developer Portal.
# ==============================================================================
SINGPASS_AUTH_V2_CLIENT_ID=
SINGPASS_AUTH_V2_OIDC_CONFIG_URL=https://stg-id.singpass.gov.sg/fapi/.well-known/openid-configuration
SINGPASS_AUTH_V2_REDIRECT_URL=
SINGPASS_AUTH_V2_CLIENT_ASSERTION_SIGN_KEY=
SINGPASS_AUTH_V2_CLIENT_ASSERTION_SIGN_KEY_ALG=ES256
SINGPASS_AUTH_V2_JWE_DECRYPT_KEY=
SINGPASS_AUTH_V2_JWE_DECRYPT_KEY_FORMAT=json
SINGPASS_AUTH_V2_DPOP_SIGN_KEY=

# ==============================================================================
# MyInfo FAPI 2.0 — MyInfo app (userinfo endpoint)
# Separate app registration in SDP with data catalog scopes (uinfin, name, etc.)
# No authenticationContextType required.
# Run the "Key generation utility" test to generate a separate key set for this app.
# ==============================================================================
MYINFO_AUTH_V2_CLIENT_ID=
MYINFO_AUTH_V2_OIDC_CONFIG_URL=https://stg-id.singpass.gov.sg/fapi/.well-known/openid-configuration
MYINFO_AUTH_V2_REDIRECT_URL=
MYINFO_AUTH_V2_CLIENT_ASSERTION_SIGN_KEY=
MYINFO_AUTH_V2_CLIENT_ASSERTION_SIGN_KEY_ALG=ES256
MYINFO_AUTH_V2_JWE_DECRYPT_KEY=
MYINFO_AUTH_V2_JWE_DECRYPT_KEY_FORMAT=json
MYINFO_AUTH_V2_DPOP_SIGN_KEY=
